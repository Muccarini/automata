{
  "name": "@automata/backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts && bun run src/db/migrate.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@automata/shared-contracts": "file:../../packages/shared-contracts",
    "drizzle-orm": "^0.44.7",
    "elysia": "^1.4.28",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.0",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
